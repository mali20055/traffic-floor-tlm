# Traffic Floor — environment variables
#
# Bu dosyayı ".env.local" olarak kopyalayıp değerleri doldurun.

# --- Sanity CMS ---
# Proje ID ve dataset herkese açık (public) tanımlayıcılardır.
# Değerleri https://www.sanity.io/manage adresinden projenizin ayarlarından alın
# (veya komut satırında: `npx sanity projects list`).
NEXT_PUBLIC_SANITY_PROJECT_ID=""
NEXT_PUBLIC_SANITY_DATASET="production"
NEXT_PUBLIC_SANITY_API_VERSION="2024-10-01"

# Yalnızca dataset'i "private" yaptıysanız veya taslak (draft) içerik okumak
# istiyorsanız gereklidir. Token oluşturmak için:
# sanity.io/manage > proje > API > Tokens > "Add API token" (Viewer yetkisi yeterli).
# Public dataset + yayınlanmış içerik için BOŞ bırakın.
SANITY_API_READ_TOKEN=""

# --- İletişim formu ---
# Formspree (veya benzeri) endpoint URL'si. Tanımlıysa /iletisim formu buraya
# POST eder; boşsa form simülasyon modunda çalışır (gerçek e-posta gitmez).
# Formspree: https://formspree.io > yeni form > endpoint'i (https://formspree.io/f/xxxx) buraya yapıştırın.
NEXT_PUBLIC_FORM_ENDPOINT=""

# --- Bakım modu ---
# "true" iken site bakım sayfası gösterir (HTTP 503). Kapatmak için "false" yapın
# veya değişkeni kaldırın. Vercel'de değiştirince yeniden deploy gerekir.
MAINTENANCE_MODE="false"
# Bakım modunda gerçek siteyi önizlemek için gizli anahtar.
# Girmek için: https://site.com/?preview=BURAYA_YAZDIGINIZ_ANAHTAR
MAINTENANCE_BYPASS_SECRET=""
